{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build"
    },
    {
      "src": "src/api/validate-username.js",
      "use": "@vercel/node"
    },
    {
      "src": "src/api/generate-certificate.js",
      "use": "@vercel/node"
    },
    {
      "src": "src/api/download-certificate.js",
      "use": "@vercel/node"
    },
    {
      "src": "src/api/admin/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/admin/(.*)",
      "dest": "/src/api/admin/index.js"
    },
    {
      "src": "/api/validate-username",
      "dest": "/src/api/validate-username.js"
    },
    {
      "src": "/api/generate-certificate",
      "dest": "/src/api/generate-certificate.js"
    },
    {
      "src": "/api/download-certificate",
      "dest": "/src/api/download-certificate.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'" }
      ]
    }
  ]
}